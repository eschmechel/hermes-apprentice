# Apprentice burst (Go) — RunPod cloud GPU burst engine. Build context = repo root.
FROM golang:1.26-bookworm AS build
WORKDIR /src/burst
COPY burst/go.mod burst/go.sum ./
RUN go mod download
COPY burst/ ./
RUN CGO_ENABLED=0 go build -o /out/burst .

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /out/burst /usr/local/bin/burst
ENTRYPOINT ["burst"]
